        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"You are an AI customer support assistant.\\n\\nAnalyze the customer's question.\\n\\nReturn ONLY valid JSON.\\n\\n{\\n  \\\"question\\\":\\\"\\\",\\n  \\\"keywords\\\":\\\"\\\",\\n  \\\"category\\\":\\\"\\\",\\n  \\\"confidence\\\":0\\n}\\n\\nRules:\\n- keywords should be comma-separated.\\n- confidence must be an integer from 0 to 100.\\n- category must be one of:\\n\\nBilling\\nTechnical\\nAccount\\nSubscription\\nAPI\\nGeneral\\n\\nCustomer question:\\n{{$json.question}}\"\n        }\n      ]\n    }\n  ]\n}",
